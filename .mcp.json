{
  "mcpServers": {
    "followupboss": {
      "command": "npx",
      "args": [
        "-y",
        "followupboss-mcp"
      ],
      "env": {
        "FOLLOWUPBOSS_API_KEY": ""
      }
    },
    "kvcore": {
      "command": "npx",
      "args": [
        "-y",
        "kvcore-mcp"
      ],
      "env": {
        "KVCORE_API_TOKEN": ""
      }
    }
  }
}

{
  "name": "kvcore-mcp",
  "version": "1.0.0",
  "description": "MCP server for kvCORE/BoldTrail CRM — search contacts, manage leads, add notes, assign tags, and view activity via Claude or any MCP client",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kvcore-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "claude",
    "crm",
    "kvcore",
    "boldtrail",
    "real-estate"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "typescript": "^5.8.3"
  }
}

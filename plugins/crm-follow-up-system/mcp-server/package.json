{
  "name": "@openclaw/followupboss-mcp",
  "version": "1.0.0",
  "description": "MCP server for Follow Up Boss CRM — search contacts, manage leads, create tasks, add notes, and automate follow-ups via Claude or any MCP client",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "followupboss-mcp": "./dist/index.js"
  },
  "files": [
